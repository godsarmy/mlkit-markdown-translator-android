<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	android:layout_width="match_parent"
	android:layout_height="match_parent" android:orientation="vertical">

	<com.google.android.material.appbar.MaterialToolbar
		android:id="@+id/translationOptionsToolbar"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:background="@android:color/transparent"
		android:contentInsetStartWithNavigation="0dp"
		android:paddingHorizontal="16dp"
		app:navigationIcon="?attr/homeAsUpIndicator"
		app:title="@string/translation_options_title"
		app:titleMarginStart="8dp"
		app:titleTextAppearance="@style/TextAppearance.MlMarkdown.ToolbarTitle" />

	<LinearLayout android:layout_width="match_parent"
		android:layout_height="match_parent" android:orientation="vertical"
		android:paddingHorizontal="16dp" android:paddingBottom="16dp">

		<ScrollView android:layout_width="match_parent"
			android:layout_height="0dp" android:layout_weight="1"
			android:fillViewport="true">

			<LinearLayout android:layout_width="match_parent"
				android:layout_height="wrap_content" android:orientation="vertical">

				<com.google.android.material.switchmaterial.SwitchMaterial
					android:id="@+id/switchPreserveNewlines"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:text="@string/label_preserve_newlines"
					android:textColor="@color/mlkit_on_background"
					app:useMaterialThemeColors="true" />

				<com.google.android.material.switchmaterial.SwitchMaterial
					android:id="@+id/switchPreserveListPrefixes"
					android:layout_width="match_parent"
					android:layout_height="wrap_content" android:layout_marginTop="8dp"
					android:text="@string/label_preserve_list_prefixes"
					android:textColor="@color/mlkit_on_background"
					app:useMaterialThemeColors="true" />

				<com.google.android.material.switchmaterial.SwitchMaterial
					android:id="@+id/switchPreserveBlockquotes"
					android:layout_width="match_parent"
					android:layout_height="wrap_content" android:layout_marginTop="8dp"
					android:text="@string/label_preserve_blockquotes"
					android:textColor="@color/mlkit_on_background"
					app:useMaterialThemeColors="true" />

				<com.google.android.material.switchmaterial.SwitchMaterial
					android:id="@+id/switchNormalizeCustomBlockTags"
					android:layout_width="match_parent"
					android:layout_height="wrap_content" android:layout_marginTop="8dp"
					android:text="@string/label_normalize_custom_block_tags"
					android:textColor="@color/mlkit_on_background"
					app:useMaterialThemeColors="true" />

				<com.google.android.material.switchmaterial.SwitchMaterial
					android:id="@+id/switchProtectAutolinks"
					android:layout_width="match_parent"
					android:layout_height="wrap_content" android:layout_marginTop="8dp"
					android:text="@string/label_protect_autolinks"
					android:textColor="@color/mlkit_on_background"
					app:useMaterialThemeColors="true" />

				<com.google.android.material.switchmaterial.SwitchMaterial
					android:id="@+id/switchEnableRegexFallbackProtection"
					android:layout_width="match_parent"
					android:layout_height="wrap_content" android:layout_marginTop="8dp"
					android:text="@string/label_enable_regex_fallback_protection"
					android:textColor="@color/mlkit_on_background"
					app:useMaterialThemeColors="true" />

				<com.google.android.material.switchmaterial.SwitchMaterial
					android:id="@+id/switchPreserveWhitespaceAroundProtectedSegments"
					android:layout_width="match_parent"
					android:layout_height="wrap_content" android:layout_marginTop="8dp"
					android:text="@string/label_preserve_whitespace_around_protected_segments"
					android:textColor="@color/mlkit_on_background"
					app:useMaterialThemeColors="true" />

				<TextView android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:layout_marginTop="20dp"
					android:text="@string/max_chars_per_chunk_label"
					android:textColor="@color/mlkit_on_surface_variant" />

				<EditText android:id="@+id/maxCharsPerChunkInput"
					android:layout_width="match_parent"
					android:layout_height="wrap_content" android:layout_marginTop="4dp"
					android:hint="@string/max_chars_per_chunk_hint"
					android:inputType="number" android:singleLine="true"
					android:textColor="@color/mlkit_on_background"
					android:textColorHint="@color/mlkit_on_surface_variant" />

				<TextView android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:layout_marginTop="10dp"
					android:text="@string/translate_timeout_ms_label"
					android:textColor="@color/mlkit_on_surface_variant" />

				<EditText android:id="@+id/translateTimeoutMsInput"
					android:layout_width="match_parent"
					android:layout_height="wrap_content" android:layout_marginTop="4dp"
					android:hint="@string/translate_timeout_ms_hint"
					android:inputType="number" android:singleLine="true"
					android:textColor="@color/mlkit_on_background"
					android:textColorHint="@color/mlkit_on_surface_variant" />

				<TextView android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:layout_marginTop="10dp"
					android:text="@string/token_marker_label"
					android:textColor="@color/mlkit_on_surface_variant" />

				<EditText android:id="@+id/tokenMarkerInput"
					android:layout_width="match_parent"
					android:layout_height="wrap_content" android:layout_marginTop="4dp"
					android:fontFamily="monospace"
					android:hint="@string/token_marker_hint" android:inputType="text"
					android:maxLength="12" android:singleLine="true"
					android:textColor="@color/mlkit_on_background"
					android:textColorHint="@color/mlkit_on_surface_variant" />

				<TextView android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:layout_marginTop="10dp"
					android:text="@string/escaped_markdown_characters_label"
					android:textColor="@color/mlkit_on_surface_variant" />

				<EditText android:id="@+id/escapedMarkdownCharactersInput"
					android:layout_width="match_parent"
					android:layout_height="wrap_content" android:layout_marginTop="4dp"
					android:fontFamily="monospace"
					android:hint="@string/escaped_markdown_characters_hint"
					android:inputType="text" android:singleLine="true"
					android:textColor="@color/mlkit_on_background"
					android:textColorHint="@color/mlkit_on_surface_variant" />

				<TextView android:layout_width="match_parent"
					android:layout_height="wrap_content" android:layout_marginTop="4dp"
					android:text="@string/escaped_markdown_characters_help"
					android:textColor="@color/mlkit_on_surface_variant" />
			</LinearLayout>
		</ScrollView>

		<LinearLayout android:layout_width="match_parent"
			android:layout_height="wrap_content" android:layout_marginTop="16dp"
			android:gravity="end" android:orientation="horizontal">

			<com.google.android.material.button.MaterialButton
				android:id="@+id/translationOptionsCancelButton"
				style="?attr/materialButtonOutlinedStyle"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content" android:layout_marginEnd="8dp"
				android:text="@string/translation_options_cancel" />

			<com.google.android.material.button.MaterialButton
				android:id="@+id/translationOptionsSaveButton"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="@string/translation_options_save" />
		</LinearLayout>
	</LinearLayout>
</LinearLayout>
