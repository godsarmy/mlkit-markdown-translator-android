<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	android:layout_width="match_parent"
	android:layout_height="wrap_content" android:orientation="vertical">

	<View android:id="@+id/sourceSelectorDivider"
		android:layout_width="match_parent" android:layout_height="1dp"
		android:layout_marginStart="12dp" android:layout_marginEnd="12dp"
		android:background="@color/mlkit_outline" android:visibility="gone" />

	<LinearLayout android:layout_width="match_parent"
		android:layout_height="wrap_content" android:gravity="center_vertical"
		android:minHeight="48dp" android:orientation="horizontal"
		android:paddingStart="12dp" android:paddingTop="8dp"
		android:paddingEnd="12dp" android:paddingBottom="8dp">

		<ImageView android:id="@+id/sourceSelectorIcon"
			android:layout_width="20dp" android:layout_height="20dp"
			android:contentDescription="@null"
			android:tint="@color/mlkit_on_surface_variant" />

		<TextView android:id="@+id/sourceSelectorText"
			android:layout_width="0dp" android:layout_height="wrap_content"
			android:layout_marginStart="10dp" android:layout_weight="1"
			android:ellipsize="end" android:maxLines="1"
			android:textColor="@color/mlkit_on_background"
			android:textSize="16sp" />
	</LinearLayout>
</LinearLayout>
