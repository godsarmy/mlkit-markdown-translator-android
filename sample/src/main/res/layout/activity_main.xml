<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	android:id="@+id/mainDrawerLayout" android:layout_width="match_parent"
	android:layout_height="match_parent" android:fitsSystemWindows="true">

	<LinearLayout android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:background="@color/mlkit_bg_canvas"
		android:orientation="vertical" android:padding="16dp">

		<androidx.appcompat.widget.AppCompatImageButton
			android:id="@+id/translationErrorButton" android:layout_width="40dp"
			android:layout_height="40dp" android:layout_gravity="end"
			android:background="@android:color/transparent"
			android:contentDescription="@string/translation_error_icon_content_description"
			android:padding="6dp" android:src="@android:drawable/ic_dialog_alert"
			android:tint="@color/mlkit_error" android:visibility="gone" />

		<LinearLayout android:id="@+id/exampleSourceContainer"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:gravity="center_vertical" android:orientation="horizontal">

			<androidx.appcompat.widget.AppCompatImageButton
				android:id="@+id/leftMenuButton" android:layout_width="40dp"
				android:layout_height="40dp" android:layout_marginEnd="4dp"
				android:background="@android:color/transparent"
				android:contentDescription="@string/left_menu_content_description"
				android:minHeight="0dp" android:minWidth="0dp" android:padding="0dp"
				android:scaleType="center" android:src="@drawable/ic_gmail_menu"
				android:tint="@color/mlkit_on_surface_variant" />

			<androidx.appcompat.widget.AppCompatAutoCompleteTextView
				android:id="@+id/sampleAssetInput" android:layout_width="0dp"
				android:layout_height="40dp" android:layout_weight="1"
				android:background="@drawable/preview_box_background"
				android:drawablePadding="10dp" android:importantForAutofill="no"
				android:inputType="none" android:maxLines="1"
				android:paddingStart="10dp" android:paddingEnd="10dp"
				android:textColor="@color/mlkit_on_background"
				android:textColorHint="@color/mlkit_on_surface_variant" />
		</LinearLayout>

		<LinearLayout android:layout_width="match_parent"
			android:layout_height="0dp" android:layout_marginTop="16dp"
			android:layout_weight="1" android:orientation="vertical">

			<TextView android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:text="@string/source_markdown_label"
				android:textColor="@color/mlkit_on_background"
				android:textStyle="bold" />

			<FrameLayout android:layout_width="match_parent"
				android:layout_height="0dp" android:layout_marginTop="8dp"
				android:layout_weight="1"
				android:background="@drawable/preview_box_background"
				android:padding="12dp">

				<EditText android:id="@+id/originalMarkdownInput"
					android:layout_width="match_parent"
					android:layout_height="match_parent"
					android:background="@android:color/transparent"
					android:fadeScrollbars="true" android:gravity="top|start"
					android:inputType="textMultiLine" android:overScrollMode="always"
					android:padding="0dp" android:scrollbarStyle="insideInset"
					android:scrollbars="vertical"
					android:text="@string/default_markdown"
					android:textColor="@color/mlkit_on_background"
					android:textColorHint="@color/mlkit_on_surface_variant" />

				<WebView android:id="@+id/inputRenderedHtml"
					android:layout_width="match_parent"
					android:layout_height="match_parent" android:visibility="gone" />
			</FrameLayout>

			<TextView android:layout_width="match_parent"
				android:layout_height="wrap_content" android:layout_marginTop="12dp"
				android:text="@string/label_output_markdown"
				android:textColor="@color/mlkit_on_background"
				android:textStyle="bold" />

			<FrameLayout android:layout_width="match_parent"
				android:layout_height="0dp" android:layout_marginTop="8dp"
				android:layout_weight="1"
				android:background="@drawable/preview_box_background"
				android:padding="12dp">

				<EditText android:id="@+id/translatedMarkdownRaw"
					android:layout_width="match_parent"
					android:layout_height="match_parent"
					android:background="@android:color/transparent"
					android:fadeScrollbars="true" android:focusable="false"
					android:focusableInTouchMode="false" android:gravity="top|start"
					android:inputType="none" android:overScrollMode="always"
					android:padding="0dp" android:scrollbarStyle="insideInset"
					android:scrollbars="vertical"
					android:textColor="@color/mlkit_on_background" />

				<WebView android:id="@+id/outputRenderedHtml"
					android:layout_width="match_parent"
					android:layout_height="match_parent" android:visibility="gone" />
			</FrameLayout>
		</LinearLayout>

		<LinearLayout android:layout_width="match_parent"
			android:layout_height="wrap_content" android:layout_marginTop="14dp"
			android:gravity="center_vertical" android:orientation="horizontal">

			<com.google.android.material.switchmaterial.SwitchMaterial
				android:id="@+id/renderModeToggle" android:layout_width="0dp"
				android:layout_height="wrap_content" android:layout_weight="1"
				android:text="@string/render_mode_switch"
				android:textColor="@color/mlkit_on_background"
				app:useMaterialThemeColors="true" />

			<androidx.appcompat.widget.AppCompatImageButton
				android:id="@+id/compareModeButton" android:layout_width="40dp"
				android:layout_height="40dp" android:layout_marginStart="8dp"
				android:background="@android:color/transparent"
				android:contentDescription="@string/compare_mode_icon_content_description"
				android:padding="6dp"
				android:src="@drawable/ic_compare_side_by_side"
				android:tint="@color/mlkit_on_surface_variant" />

			<androidx.appcompat.widget.AppCompatImageButton
				android:id="@+id/shareTranslatedButton" android:layout_width="40dp"
				android:layout_height="40dp" android:layout_marginStart="4dp"
				android:background="@android:color/transparent"
				android:contentDescription="@string/share_translated_markdown_content_description"
				android:padding="6dp" android:src="@drawable/ic_share"
				android:tint="@color/mlkit_on_surface_variant" />
		</LinearLayout>


		<LinearLayout android:layout_width="match_parent"
			android:layout_height="wrap_content" android:layout_marginTop="6dp"
			android:gravity="bottom" android:orientation="horizontal">

			<LinearLayout android:layout_width="0dp"
				android:layout_height="wrap_content" android:layout_weight="1"
				android:orientation="vertical">

				<TextView android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="@string/source_language_label"
					android:textColor="@color/mlkit_on_surface_variant" />

				<Spinner android:id="@+id/sourceLanguageSpinner"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:entries="@array/language_codes" />
			</LinearLayout>

			<Space android:layout_width="12dp" android:layout_height="1dp" />

			<LinearLayout android:layout_width="0dp"
				android:layout_height="wrap_content" android:layout_weight="1"
				android:orientation="vertical">

				<TextView android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="@string/target_language_label"
					android:textColor="@color/mlkit_on_surface_variant" />

				<Spinner android:id="@+id/targetLanguageSpinner"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:entries="@array/language_codes" />
			</LinearLayout>

		</LinearLayout>

		<LinearLayout android:layout_width="match_parent"
			android:layout_height="wrap_content" android:layout_marginTop="8dp"
			android:baselineAligned="false" android:gravity="center_vertical"
			android:orientation="horizontal">

			<com.google.android.material.button.MaterialButton
				android:id="@+id/explainButton" android:layout_width="0dp"
				android:layout_height="52dp" android:layout_weight="1"
				android:elevation="0dp" android:insetLeft="0dp"
				android:insetRight="0dp" android:minWidth="0dp"
				android:paddingStart="14dp" android:paddingEnd="14dp"
				android:stateListAnimator="@null"
				android:text="@string/explain_markdown" android:textAllCaps="false"
				android:textColor="@android:color/white"
				app:backgroundTint="@color/mlkit_primary" app:cornerRadius="14dp" />

			<Space android:layout_width="10dp" android:layout_height="1dp" />

			<com.google.android.material.button.MaterialButton
				android:id="@+id/translateButton" android:layout_width="0dp"
				android:layout_height="52dp" android:layout_weight="1"
				android:elevation="0dp" android:stateListAnimator="@null"
				android:text="@string/translate_markdown"
				android:textAllCaps="false"
				android:textColor="@color/translate_button_text_color"
				app:backgroundTint="@color/translate_button_background_tint"
				app:cornerRadius="14dp" />
		</LinearLayout>

		<FrameLayout android:layout_width="match_parent"
			android:layout_height="wrap_content" android:layout_marginTop="8dp">

			<TextView android:id="@+id/translationResultText"
				android:layout_width="match_parent"
				android:layout_height="wrap_content" android:ellipsize="end"
				android:maxLines="3" android:minLines="3"
				android:textColor="@color/mlkit_on_surface_variant"
				android:visibility="invisible" />

			<LinearLayout
				android:id="@+id/translationProgressContainer"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:gravity="center_vertical" android:orientation="horizontal"
				android:visibility="invisible">

				<com.google.android.material.progressindicator.CircularProgressIndicator
					android:id="@+id/translationProgressBar"
					android:layout_width="20dp" android:layout_height="20dp"
					android:indeterminate="true"
					app:indicatorColor="@color/mlkit_primary" app:indicatorInset="0dp"
					app:indicatorSize="20dp" app:trackColor="@color/mlkit_outline"
					app:trackThickness="2dp" />

				<TextView android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_marginStart="8dp"
					android:text="@string/status_translating"
					android:textColor="@color/mlkit_on_surface_variant" />
			</LinearLayout>
		</FrameLayout>

	</LinearLayout>

	<com.google.android.material.navigation.NavigationView
		android:id="@+id/leftNavigationView"
		android:layout_width="wrap_content"
		android:layout_height="match_parent" android:layout_gravity="start"
		android:background="@color/mlkit_bg_canvas"
		android:fitsSystemWindows="true"
		app:headerLayout="@layout/nav_header_main"
		app:itemIconTint="@color/mlkit_on_surface_variant"
		app:itemTextColor="@color/mlkit_on_background"
		app:menu="@menu/main_drawer_menu" />

</androidx.drawerlayout.widget.DrawerLayout>
